# ── PostgreSQL ─────────────────────────────────────
POSTGRES_DB=aircargo
POSTGRES_USER=aircargo_user
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_PORT=5432

# ── JWT (min 32 chars, generate with: openssl rand -hex 32) ──
JWT_SECRET=your_random_32_char_min_secret_here

# ── Ports (host) ──────────────────────────────────
FRONTEND_PORT=80
BACKEND_PORT=9091

# ── CORS (comma-separated origins) ───────────────
CORS_ORIGINS=http://localhost,http://localhost:80

# ── Java heap (for t3.small: 512m, t3.medium: 1g) ──
JAVA_OPTS=-Xms256m -Xmx512m
